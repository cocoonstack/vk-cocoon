# vk-cocoon environment overrides. Drop a customized copy at
# /etc/cocoon/vk-cocoon.env on each cocoon node.

# Virtual node name registered with the K8s API.
VK_NODE_NAME=cocoon-pool

# Cocoon pool label stamped onto the registered node.
VK_NODE_POOL=default

# Cloud-provider backing instance for the virtual node. On GKE this
# prevents the cloud node lifecycle controller from deleting the
# virtual node as "not found in cloud provider".
#VK_PROVIDER_ID=gce://<project>/<zone>/<instance>

# Kubeconfig used to talk to the API server. The systemd unit
# already exports KUBECONFIG=/etc/cocoon/kubeconfig; uncomment to
# override.
#KUBECONFIG=/etc/cocoon/kubeconfig

# Log level for the projecteru2/core/log facade.
VK_LOG_LEVEL=info

# Epoch registry endpoint and (optional) bearer token. The /dl/
# routes are anonymous, so the token is only needed for /v2/
# pushes.
EPOCH_URL=http://epoch.cocoon-system.svc:8080
#EPOCH_TOKEN=

# cocoon-net JSON lease file path (default shown).
VK_LEASES_PATH=/var/lib/cocoon/net/leases.json

# Path to the cocoon CLI binary. Empty defaults to /usr/local/bin/cocoon.
#VK_COCOON_BIN=

# SSH credentials used by GetContainerLogs / RunInContainer to
# reach Linux guests.
VK_SSH_PASSWORD=

# Orphan-VM policy applied during startup reconcile:
#   alert    log + metric, do not touch the VM (default, safest)
#   destroy  remove the orphan VM
#   keep     no log, no metric
VK_ORPHAN_POLICY=alert

# Plain-HTTP metrics listener.
VK_METRICS_ADDR=:9091
